    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body ?? input;\nconst event = body.event ?? '';\nconst eventName = String(event).toLowerCase();\nconst data = body.data ?? {};\nconst key = data.key ?? {};\nconst message = data.message ?? {};\nconst messageType = data.messageType ?? '';\n\nconst remoteJid = key.remoteJidAlt || key.remoteJid || '';\nconst senderNumber = remoteJid.split('@')[0] || '';\n\nconst isMessageEvent = !eventName || eventName.includes('message');\nconst isGroup = remoteJid.endsWith('@g.us');\nconst fromMe = key.fromMe === true;\n\nlet text = '';\nif (messageType === 'conversation') {\n  text = message.conversation ?? \"\";\n} else if (messageType === 'extendedTextMessage') {\n  text = message.extendedTextMessage?.text ?? \"\";\n} else if (messageType === 'imageMessage') {\n  text = message.imageMessage?.caption ?? \"\";\n} else if (messageType === 'documentMessage') {\n  text = message.documentMessage?.caption ?? \"\";\n}\n\nlet simpleType = 'unsupported';\nif (messageType === 'conversation' || messageType === 'extendedTextMessage') simpleType = 'text';\nif (messageType === 'imageMessage') simpleType = 'image';\nif (messageType === 'audioMessage') simpleType = 'audio';\nif (messageType === 'documentMessage') simpleType = 'document';\nif (messageType === 'stickerMessage') simpleType = 'sticker';\nif (messageType === 'reactionMessage') simpleType = 'reaction';\n\nconst normalized = String(text || \"\").trim();\nconst normalizedLower = normalized.toLowerCase();\n\n// Persistent state by chat\nlet staticData = {};\nif (typeof $getWorkflowStaticData === \"function\") {\n  staticData = $getWorkflowStaticData(\"global\");\n} else {\n  globalThis.__agentState = globalThis.__agentState || {};\n  staticData = globalThis.__agentState;\n}\nstaticData.chatStates = staticData.chatStates || {};\nconst chatKey = remoteJid || senderNumber || \"unknown\";\nconst currentState = staticData.chatStates[chatKey] || { enabled: false, contextLimit: 20 };\n\nlet nextState = { ...currentState };\nlet type = simpleType;\nlet ignore = false;\nlet ignoreReason = '';\nlet commandReply = '';\nlet contextLimit = currentState.contextLimit || 20;\nlet userPrompt = text;\n\nconst isDotShort = fromMe && (normalizedLower === \".\" || normalizedLower.startsWith(\". \"));\nconst isDotLong = fromMe && (normalizedLower === \"..\" || normalizedLower.startsWith(\".. \"));\nconst isOff = fromMe && normalizedLower === \"um minuto\";\n\nif (isOff) {\n  nextState.enabled = false;\n  nextState.contextLimit = currentState.contextLimit || 20;\n  staticData.chatStates[chatKey] = nextState;\n  type = \"command\";\n  commandReply = \"Agente desligado neste chat.\";\n  ignore = false;\n} else if (isDotLong) {\n  nextState.enabled = true;\n  nextState.contextLimit = 100;\n  staticData.chatStates[chatKey] = nextState;\n  contextLimit = 100;\n  if (normalizedLower === \"..\") {\n    type = \"command\";\n    commandReply = \"Agente ligado neste chat com contexto amplo (100 mensagens).\";\n    ignore = false;\n  } else {\n    type = \"text\";\n    userPrompt = normalized.slice(2).trim();\n    if (!userPrompt) {\n      type = \"command\";\n      commandReply = \"Agente ligado neste chat com contexto amplo (100 mensagens).\";\n    }\n  }\n} else if (isDotShort) {\n  nextState.enabled = true;\n  nextState.contextLimit = 20;\n  staticData.chatStates[chatKey] = nextState;\n  contextLimit = 20;\n  if (normalizedLower === \".\") {\n    type = \"command\";\n    commandReply = \"Agente ligado neste chat com contexto curto (20 mensagens).\";\n    ignore = false;\n  } else {\n    type = \"text\";\n    userPrompt = normalized.slice(1).trim();\n    if (!userPrompt) {\n      type = \"command\";\n      commandReply = \"Agente ligado neste chat com contexto curto (20 mensagens).\";\n    }\n  }\n} else {\n  contextLimit = currentState.contextLimit || 20;\n  if (!isMessageEvent) {\n    ignore = true;\n    ignoreReason = \"not_message_event\";\n  } else if (!senderNumber) {\n    ignore = true;\n    ignoreReason = \"missing_sender\";\n  } else if (isGroup) {\n    ignore = true;\n    ignoreReason = \"group\";\n  } else if (type === \"reaction\") {\n    ignore = true;\n    ignoreReason = \"reaction\";\n  } else if (type === \"unsupported\") {\n    ignore = true;\n    ignoreReason = \"unsupported\";\n  } else if (fromMe) {\n    ignore = true;\n    ignoreReason = \"from_me\";\n  } else if (!currentState.enabled) {\n    ignore = true;\n    ignoreReason = \"agent_off\";\n  } else if (type === \"text\" && !String(userPrompt || \"\").trim()) {\n    ignore = true;\n    ignoreReason = \"empty_text\";\n  }\n}\n\nreturn {\n  event,\n  ignore,\n  ignoreReason,\n  sender: remoteJid,\n  senderNumber,\n  pushName: data.pushName ?? body.sender ?? \"\",\n  type,\n  text,\n  userPrompt,\n  commandReply,\n  contextLimit,\n  raw_message: message,\n  raw_type: messageType,\n  evolutionData: data,\n  chatState: staticData.chatStates[chatKey] || currentState,\n};"
      },

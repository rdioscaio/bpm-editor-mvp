        "method": "POST",
        "url": "={{ $(\"CONFIG_EVOLUTION\").item.json.evolution_url }}/chat/getBase64FromMediaMessage/{{ $(\"CONFIG_EVOLUTION\").item.json.instance }}",
        "sendHeaders": true,

      "id": "91f7e9a9-0f2d-4c1f-97ad-4aef4015da6e",
      "name": "Obter Midia Base64",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        912,
        256
      ]
    },
    {
      "parameters": {
        "jsCode": "const media = $input.first().json;\nconst msg = $('Adaptar Evolution').item.json;\n\nconst type = msg.type;\nconst caption = (msg.text || '').trim();\nconst mimeRaw = media.mimetype || 'application/octet-stream';\nconst mimeType = String(mimeRaw).split(';')[0] || mimeRaw;\n\nlet instruction = 'Responda em portugues de forma objetiva.';\nif (type === 'image') {\n  instruction = 'Analise a imagem e responda em portugues de forma objetiva. Se houver texto, extraia os pontos principais.';\n} else if (type === 'audio') {\n  instruction = 'Transcreva o audio e responda em portugues de forma objetiva.';\n} else if (type === 'document') {\n  instruction = 'Leia o documento e responda em portugues de forma objetiva, destacando os pontos principais.';\n} else if (type === 'sticker') {\n  instruction = 'Interprete a figurinha (sticker) e explique a intencao ou emocao em portugues de forma objetiva.';\n}\n\nconst contextText = caption ? ('Texto enviado junto com a midia: \"' + caption + '\"') : 'O usuario enviou apenas a midia, sem texto adicional.';\n\nreturn {\n  geminiRequest: {\n    contents: [\n      {\n        parts: [\n          { text: instruction + \"\\n\" + contextText },\n          {\n            inline_data: {\n              mime_type: mimeType,\n              data: media.base64,\n            },\n          },\n        ],\n      },\n    ],\n  },\n};"
      },
      "id": "b19adf7f-e0f6-4cb5-b351-844596b6a628",
      "name": "Preparar Prompt Midia",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        256
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ \"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=\" + $(\"CONFIG_EVOLUTION\").item.json.gemini_api_key }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.geminiRequest }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "53f6d2e8-b8c9-4765-9d9d-37fb9e30360b",
      "name": "Gemini Midia",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1360,
        256
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst parts = data?.candidates?.[0]?.content?.parts ?? [];\nconst output = parts\n  .map((p) => p?.text)\n  .filter(Boolean)\n  .join('\\n')\n  .trim();\n\nconst err = data?.error?.message ? String(data.error.message) : '';\n\nreturn {\n  output: output || (err ? ('Nao consegui processar a midia agora: ' + err) : 'Nao consegui processar a midia agora. Tente novamente.'),\n};"
      },
      "id": "f37d95ce-6e9c-4bd9-b902-0425d1d59fd5",
      "name": "Extrair Resposta Midia",

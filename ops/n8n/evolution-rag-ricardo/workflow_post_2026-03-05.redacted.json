    {
      "parameters": {
        "method": "POST",
        "url": "={{ $(\"CONFIG_EVOLUTION\").item.json.evolution_url }}/chat/findMessages/{{ $(\"CONFIG_EVOLUTION\").item.json.instance }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "<REDACTED>"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"where\": { \"key\": { \"remoteJid\": $(\"Adaptar Evolution\").item.json.sender } }, \"limit\": $(\"Adaptar Evolution\").item.json.contextLimit } }}",
        "options": {}
      },
      "id": "5e8dcb7c-2f68-4e8f-ac4a-57490ea5f6f1",
      "name": "Buscar Contexto Chat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        896,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "const adapted = $(\"Adaptar Evolution\").item.json;\nconst records = $input.first().json?.messages?.records ?? [];\nconst limit = Number(adapted.contextLimit || 20);\nconst supported = new Set([\"conversation\",\"extendedTextMessage\",\"imageMessage\",\"audioMessage\",\"documentMessage\",\"stickerMessage\"]);\n\nfunction extractContent(rec) {\n  const mt = rec?.messageType || \"\";\n  const m = rec?.message || {};\n  if (mt === \"conversation\") return m.conversation || \"\";\n  if (mt === \"extendedTextMessage\") return m.extendedTextMessage?.text || \"\";\n  if (mt === \"imageMessage\") return m.imageMessage?.caption || \"[imagem]\";\n  if (mt === \"audioMessage\") return \"[audio]\";\n  if (mt === \"documentMessage\") return m.documentMessage?.caption || \"[documento]\";\n  if (mt === \"stickerMessage\") return \"[figurinha]\";\n  return \"\";\n}\n\nconst contextLines = records\n  .filter((r) => supported.has(String(r.messageType || \"\")))\n  .slice(0, limit)\n  .reverse()\n  .map((r) => {\n    const who = r?.key?.fromMe ? \"EU\" : \"CONTATO\";\n    const content = extractContent(r);\n    const mt = r?.messageType || \"\";\n    if (!content) return \"\";\n    return `[${who}] (${mt}) ${content}`;\n  })\n  .filter(Boolean);\n\nconst prompt = [\n  \"Contexto recente da conversa (do mais antigo para o mais novo):\",\n  contextLines.join(\"\\n\") || \"(sem contexto recente)\",\n  \"\",\n  \"Mensagem atual do contato:\",\n  adapted.userPrompt || adapted.text || \"\",\n  \"\",\n  \"Instrucoes: responda em portugues, de forma objetiva; nao invente fatos; se faltar contexto, pergunte curto.\",\n].join(\"\\n\");\n\nreturn { text: prompt };"
      },
      "id": "4c9b4f6d-2f05-4a1a-8525-fafdb70ef5f8",
      "name": "Montar Prompt Contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        80
      ]
    }
